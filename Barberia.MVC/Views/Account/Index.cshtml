@{
    ViewData["Title"] = "Iniciar Sesión - Navaja de Plata";
}

<div class="full-bg-barber">

    <div class="container h-100 d-flex align-items-center">
        <div class="row w-100 gx-5 align-items-center">

            <div class="col-md-6 d-none d-md-block">
                <div class="image-box shadow-lg">
                    <img src="https://images.pexels.com/photos/15168271/pexels-photo-15168271.jpeg"
                         class="img-fluid rounded-4" alt="Barbería">
                </div>
            </div>

            <div class="col-md-6 col-12">
                <div class="login-card-elite">
                    <div class="text-center pt-4">
                        <i class="bi bi-person-circle text-silver" style="font-size: 3rem;"></i>
                        <h2 class="text-white fw-bold mt-2 tracking-wider">SISTEMA DE BARBERÍA</h2>
                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert alert-danger text-center fw-bold py-2 mb-3" style="background: rgba(220, 53, 69, 0.2); border: 1px solid #dc3545; color: #ff6b6b; font-size: 0.8rem;">
                                <i class="bi bi-x-circle-fill me-2"></i> @ViewBag.ErrorMessage
                            </div>
                        }
                        <p class="text-white-50 small">Ingrese sus credenciales</p>
                    </div>

                    <form asp-action="Login" asp-controller="Account" method="post" class="p-4">
                        <div class="mb-3 text-start">
                            <label class="text-silver small fw-bold text-uppercase mb-1">Correo Electrónico</label>
                            <input type="email" name="email" class="barber-input" placeholder="usuario@barberia.com" required>
                        </div>
                        <div class="mb-4 text-start">
                            <label class="text-silver small fw-bold text-uppercase mb-1">Contraseña</label>
                            <input type="password" name="password" class="barber-input" placeholder="********" required>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn-entrar">ENTRAR AL SISTEMA</button>
                            <div class="underline-barber mx-auto"></div>
                        </div>
                    </form>

                    <div class="text-center pb-4">
                        <a asp-action="Register" class="text-silver-link small text-decoration-none">¿No tienes cuenta? Regístrate aquí</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    /* ELIMINAR CUALQUIER MARGEN DEL CUERPO */
    body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    /* FONDO TOTAL DE LADO A LADO */
    .full-bg-barber {
        background: linear-gradient(135deg, #000000 0%, #001a33 100%);
        position: fixed; /* Se pega a la pantalla */
        top: 56px; /* Empieza justo debajo de la barra */
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 1000;
        display: flex;
        overflow-y: auto; /* Por si la pantalla es pequeña, deja bajar */
    }

    /* Cuadro de Login con borde de poste */
    .login-card-elite {
        background: #1a1a1a;
        border-radius: 10px;
        border: 4px solid;
        border-image: linear-gradient(0deg, #dc3545 0%, #dc3545 20%, #ffffff 20%, #ffffff 40%, #0056b3 40%, #0056b3 60%, #ffffff 60%, #ffffff 80%, #dc3545 80%, #dc3545 100% );
        border-image-slice: 1;
    }

    /* Inputs negros */
    .barber-input {
        width: 100%;
        background: #000;
        border: 1px solid #444;
        color: white;
        padding: 12px;
        border-radius: 8px;
    }

        .barber-input:focus {
            outline: none;
            border-color: #c0c0c0;
        }

    /* Estilos de texto y botones */
    .btn-entrar {
        background: none;
        border: none;
        color: white;
        font-weight: bold;
        letter-spacing: 2px;
    }

    .underline-barber {
        height: 3px;
        width: 100px;
        background: linear-gradient(90deg, #dc3545 0%, #0056b3 100%);
        margin-top: 5px;
    }

    .text-silver {
        color: #c0c0c0;
    }

    .text-silver-link {
        color: #888;
        transition: 0.3s;
    }

        .text-silver-link:hover {
            color: #fff;
        }

    .tracking-wider {
        letter-spacing: 2px;
    }

    .image-box img {
        border: 2px solid #333;
        box-shadow: 0 0 30px rgba(0,0,0,0.5);
    }
</style>