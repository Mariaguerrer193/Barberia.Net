@{
    ViewData["Title"] = "Acceso Admin - Navaja de Plata";
}

<div class="p-0 mb-4 bg-dark rounded-3 shadow-lg position-relative overflow-hidden border-bottom border-danger"
     style="background: radial-gradient(circle at center, rgba(0,0,0,0.5), rgba(0,0,0,0.9)),
            url('https://images.unsplash.com/photo-1503951914875-452162b0f3f1?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80');
            background-size: cover; background-position: center; min-height: 100vh; border-top: 5px solid #0056b3;">

    <div class="container d-flex flex-column justify-content-center align-items-center text-center" style="min-height: 100vh;">

        <div class="py-5 px-5 shadow-lg" style="border-left: 5px solid #dc3545; border-right: 5px solid #0056b3; border-radius: 10px; background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); max-width: 450px; width: 100%;">

            <h2 class="text-white fw-bold mb-4 tracking-wider" style="color: #c0c0c0 !important;">ACCESO ADMIN</h2>

            <form asp-action="Validar" asp-controller="Admin" method="post">
                <div class="mb-4">
                    <label class="text-white-50 small fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 2px;">Codigo de Seguridad</label>
                    <input type="password" name="codigoAdmin" class="barber-input" placeholder="********" required autofocus>

                    @if (ViewBag.Error != null)
                    {
                        <div class="text-danger small fw-bold mt-3 text-uppercase">
                            @ViewBag.Error
                        </div>
                    }
                </div>

                <div class="d-grid gap-3">
                    <button type="submit" class="btn-barber-azul">ENVIAR</button>
                    <a asp-controller="Home" asp-action="Index" class="text-white-50 small text-decoration-none mt-2">
                        Volver al inicio
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Mantenemos tus estilos originales para que no cambie nada visualmente */
    body {
        background-color: #000 !important;
        margin: 0;
        padding: 0;
    }

    .barber-input {
        width: 100%;
        background: #000;
        border: 1px solid #444;
        color: white;
        padding: 12px;
        border-radius: 5px;
        text-align: center;
    }

    .btn-barber-azul {
        background: linear-gradient(90deg, #0056b3 0%, #dc3545 100%);
        color: white;
        padding: 15px 35px;
        border: 2px solid #c0c0c0;
        border-radius: 5px;
        text-decoration: none;
        font-weight: bold;
        letter-spacing: 1px;
        cursor: pointer;
    }

    .tracking-wider {
        letter-spacing: 3px;
    }
</style>