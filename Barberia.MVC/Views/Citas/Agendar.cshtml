@model Barberia.Modelos.Cita
@using Microsoft.AspNetCore.Http

<div class="full-bg-barber d-flex align-items-center justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="gradient-border-box">
            <div class="create-card p-4 p-md-5">
                <div class="text-center mb-4">
                    <h2 class="text-white fw-bold tracking-wider">RESERVAR CITA</h2>
                    <div class="underline-white mx-auto"></div>
                </div>

                <form asp-action="Agendar" method="post">
                    @* Se obtiene el ID del cliente de la sesión *@
                    <input type="hidden" name="ClienteId" value="@Context.Session.GetInt32("UserId")" />

                    <div class="form-group mb-3">
                        <label class="label-custom">BARBERO DE PREFERENCIA</label>
                        <select asp-for="BarberoId" class="barber-input-field" asp-items="ViewBag.Barberos" required>
                            <option value="">-- Selecciona a tu barbero --</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label class="label-custom">SERVICIO A REALIZAR</label>
                        <select asp-for="ServicioId" class="barber-input-field" asp-items="ViewBag.Servicios" required>
                            <option value="">-- Elige el servicio --</option>
                        </select>
                    </div>

                    <div class="form-group mb-4">
                        <label class="label-custom">FECHA Y HORA</label>
                        <select asp-for="HorarioId" class="barber-input-field" asp-items="ViewBag.Horarios" required>
                            <option value="">-- Selecciona el horario --</option>
                        </select>
                    </div>

                    @* --- BLOQUE DE ERROR POR SI EL BARBERO ESTÁ OCUPADO --- *@
                    @if (ViewBag.ErrorDisponibilidad != null)
                    {
                        <div class="alert alert-danger text-center fw-bold mb-3 py-2" style="background: rgba(220, 53, 69, 0.2); border: 1px solid #dc3545; color: #ff6b6b; font-size: 0.8rem;">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorDisponibilidad
                        </div>
                    }

                    <div class="d-grid gap-3 mt-4">
                        <button type="submit" class="btn-white-custom">CONFIRMAR MI CITA</button>
                        <a asp-action="MisCitas" class="btn-back-link text-center">CANCELAR Y VOLVER</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Tus estilos se mantienen exactamente igual */
    .full-bg-barber {
        background: radial-gradient(circle at center, rgba(0,0,0,0.8), rgba(0,0,0,0.95)), url('https://images.unsplash.com/photo-1512690196236-d5a232933339?auto=format&fit=crop&w=1350&q=80');
        background-size: cover;
        min-height: 100vh;
    }

    .gradient-border-box {
        background: linear-gradient(135deg, #dc3545 0%, #0056b3 100%);
        padding: 2px;
        border-radius: 15px;
    }

    .create-card {
        background: #0a0a0a;
        border-radius: 13px;
    }

    .underline-white {
        height: 3px;
        width: 60px;
        background: white;
        margin-top: 5px;
        border-radius: 2px;
    }

    .label-custom {
        color: #a6a6a6 !important;
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 1.5px;
        margin-bottom: 8px;
        display: block;
    }

    .barber-input-field {
        width: 100%;
        background: #111 !important;
        border: 1px solid #333 !important;
        color: white !important;
        padding: 12px;
        border-radius: 8px;
    }

    .btn-white-custom {
        background: white;
        color: black;
        padding: 14px;
        border: none;
        border-radius: 8px;
        font-weight: 900;
        text-transform: uppercase;
        transition: 0.3s;
    }

        .btn-white-custom:hover {
            background: #f0f0f0;
            transform: translateY(-2px);
        }

    .btn-back-link {
        color: white;
        opacity: 0.6;
        text-decoration: underline;
        font-size: 0.85rem;
    }

        .btn-back-link:hover {
            opacity: 1;
        }
</style>