@model Barberia.Modelos.Cita

@{
    ViewData["Title"] = "Editar Cita";
}

<div class="full-bg-barber d-flex align-items-center justify-content-center">
    <div class="col-md-7 col-lg-6">

        <div class="edit-card shadow-lg p-4 p-md-5 my-4">
            <div class="text-center mb-4">
                <i class="bi bi-calendar2-check text-silver fs-1"></i>
                <h2 class="text-white fw-bold tracking-wider mt-2">EDITAR CITA</h2>
                <div class="underline-barber mx-auto"></div>
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                @Html.HiddenFor(model => model.Id)

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label text-silver fw-bold small text-uppercase">Cliente</label>
                        <select asp-for="ClienteId" class="barber-input" asp-items="ViewBag.Clientes">
                            <option value="">-- Seleccione Cliente --</option>
                        </select>
                        <span asp-validation-for="ClienteId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label text-silver fw-bold small text-uppercase">Barbero</label>
                        <select asp-for="BarberoId" class="barber-input" asp-items="ViewBag.Barberos">
                            <option value="">-- Seleccione Barbero --</option>
                        </select>
                        <span asp-validation-for="BarberoId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label text-silver fw-bold small text-uppercase">Servicio</label>
                        <select asp-for="ServicioId" class="barber-input" asp-items="ViewBag.Servicios">
                            <option value="">-- Seleccione Servicio --</option>
                        </select>
                        <span asp-validation-for="ServicioId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label text-silver fw-bold small text-uppercase">Horario</label>
                        <select asp-for="HorarioId" class="barber-input" asp-items="ViewBag.Horarios">
                            <option value="">-- Seleccione Horario --</option>
                        </select>
                        <span asp-validation-for="HorarioId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-grid gap-3 mt-4">
                    <button type="submit" class="btn-guardar">
                        <i class="bi bi-check-lg me-2"></i>GUARDAR CAMBIOS
                    </button>
                    <a asp-action="Index" class="btn-volver text-center">
                        <i class="bi bi-arrow-left me-2"></i>REGRESAR A LA LISTA
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* FONDO TOTAL CON FOTO */
    .full-bg-barber {
        background: radial-gradient(circle at center, rgba(0,0,0,0.6), rgba(0,0,0,0.9)), url('https://images.unsplash.com/photo-1512690196236-d5a232933339?auto=format&fit=crop&w=1350&q=80');
        background-size: cover;
        background-position: center;
        min-height: 100vh;
        width: 100%;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1000;
        padding-top: 60px;
        overflow-y: auto;
    }

    .edit-card {
        background: rgba(15, 15, 15, 0.95);
        border: 2px solid #c0c0c0;
        border-radius: 15px;
        backdrop-filter: blur(10px);
    }

    .underline-barber {
        height: 4px;
        width: 80px;
        background: linear-gradient(90deg, #dc3545 0%, #001a33 100%);
        border-radius: 2px;
    }

    /* ESTILO OSCURO PARA LOS SELECTS */
    .barber-input {
        width: 100%;
        background: #000 !important;
        border: 1px solid #444 !important;
        color: white !important;
        padding: 12px;
        border-radius: 6px;
        cursor: pointer;
    }

        .barber-input option {
            background-color: #111;
            color: white;
        }

        .barber-input:focus {
            border-color: #dc3545 !important;
            box-shadow: 0 0 8px rgba(220, 53, 69, 0.3);
            outline: none;
        }

    /* BOTÓN DEGRADADO ROJO A AZUL MARINO */
    .btn-guardar {
        background: linear-gradient(90deg, #dc3545 0%, #001a33 100%);
        color: white;
        padding: 12px;
        border: 1px solid #c0c0c0;
        border-radius: 6px;
        font-weight: bold;
        transition: 0.3s;
        cursor: pointer;
    }

        .btn-guardar:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(220, 53, 69, 0.4);
        }

    .btn-volver {
        color: #c0c0c0;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-volver:hover {
            color: white;
            text-decoration: underline;
        }

    .text-silver {
        color: #c0c0c0;
    }

    .tracking-wider {
        letter-spacing: 2px;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}