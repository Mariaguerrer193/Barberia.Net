@model IEnumerable<Barberia.Modelos.Cita>

@{
    ViewData["Title"] = "Index";
    // Traemos las listas del ViewBag para buscar los nombres
    var clientes = ViewBag.Clientes as List<Barberia.Modelos.Cliente>;
    var barberos = ViewBag.Barberos as List<Barberia.Modelos.Barbero>;
    var servicios = ViewBag.Servicios as List<Barberia.Modelos.Servicio>;
    var horarios = ViewBag.Horarios as List<Barberia.Modelos.Horario>;
}

<div class="full-bg-barber">
    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h1 class="text-white fw-bold mb-0 tracking-wider">CITAS</h1>
                <div class="underline-barber"></div>
            </div>
            <a asp-action="Create" class="btn-nuevo">
                <i class="bi bi-plus-circle me-2"></i>CREATE NEW
            </a>
        </div>

        <div class="table-container shadow-lg">
            <table class="table table-dark mb-0">
                <thead>
                    <tr class="header-gradient-row">
                        <th class="text-bright-white">ID</th>
                        <th class="text-bright-white">Cliente</th>
                        <th class="text-bright-white">Barbero</th>
                        <th class="text-bright-white">Servicio</th>
                        <th class="text-bright-white">Horario</th>
                        <th class="text-bright-white text-end">ADMINISTRAR</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        // LÓGICA PARA BUSCAR NOMBRES POR ID
                        var cliente = clientes?.FirstOrDefault(c => c.Id == item.ClienteId);
                        var barbero = barberos?.FirstOrDefault(b => b.Id == item.BarberoId);
                        var servicio = servicios?.FirstOrDefault(s => s.Id == item.ServicioId);
                        var horario = horarios?.FirstOrDefault(h => h.Id == item.HorarioId);

                        <tr>
                            <td>@item.Id</td>

                            <td>
                                <span class="text-white fw-bold">
                                    @(cliente != null ? $"{cliente.Nombre_Cli} {cliente.Apellido_Cli}" : "N/A")
                                </span>
                            </td>

                            <td>
                                <span class="text-silver">
                                    @(barbero != null ? $"{barbero.Nombre_Bar} {barbero.Apellido_Bar}" : "N/A")
                                </span>
                            </td>

                            <td>
                                <span class="badge bg-dark border border-secondary text-silver">
                                    @(servicio != null ? servicio.Nombre_Serv : "N/A")
                                </span>
                            </td>

                            <td class="small">
                                @if (horario != null)
                                {
                                    <div class="text-white">@horario.Fecha.ToString("dd/MM/yyyy")</div>
                                    <div class="text-white-50">@horario.HoraInicio.ToString(@"hh\:mm")</div>
                                }
                                else
                                {

                                    <span>N/A</span>
                                }
                            </td>

                            <td class="links-acciones text-end">
                                @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |
                                @Html.ActionLink("Details", "Details", new { id = item.Id }) |
                                @Html.ActionLink("Delete", "Delete", new { id = item.Id })
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* El resto de tu estilo se mantiene igual... */
    .full-bg-barber {
        background: linear-gradient(135deg, #001a33 0%, #000000 50%, #330000 100%);
        position: fixed;
        top: 56px;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 1000;
        overflow-y: auto;
    }

    .underline-barber {
        height: 4px;
        width: 120px;
        background: linear-gradient(90deg, #dc3545 0%, #0056b3 100%);
        margin-top: 8px;
        border-radius: 2px;
    }

    .table-container {
        border: 2px solid #c0c0c0;
        border-radius: 10px;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.8);
    }

    .table {
        color: white;
        margin-bottom: 0;
        border-collapse: collapse;
        width: 100%;
    }

    .header-gradient-row {
        position: relative;
    }

        .header-gradient-row th {
            border-bottom: none !important;
            padding-bottom: 15px !important;
        }

        .header-gradient-row::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #0056b3 0%, #dc3545 100%);
        }

    .text-bright-white {
        color: #ffffff !important;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 2px;
    }

    .tracking-wider {
        letter-spacing: 3px;
    }

    .table > :not(caption) > * > * {
        box-shadow: none !important;
        background-color: transparent !important;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .btn-nuevo {
        color: white;
        text-decoration: none;
        background: linear-gradient(90deg, #0056b3 0%, #dc3545 100%);
        padding: 10px 25px;
        border: 1px solid #c0c0c0;
        border-radius: 5px;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-nuevo:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(0, 86, 179, 0.4);
        }

    .links-acciones {
        color: #666;
    }

        .links-acciones a {
            text-decoration: none;
            font-weight: bold;
            font-size: 0.9rem;
            transition: 0.2s;
            margin: 0 3px;
        }

            .links-acciones a[href*="Edit"] {
                color: #00aaff;
            }

            .links-acciones a[href*="Details"] {
                color: #ffffff;
            }

            .links-acciones a[href*="Delete"] {
                color: #ff4444;
            }

            .links-acciones a:hover {
                text-decoration: underline;
                filter: brightness(1.3);
            }
</style>