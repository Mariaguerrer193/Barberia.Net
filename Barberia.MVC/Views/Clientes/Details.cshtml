@model Barberia.Modelos.Cliente

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="full-bg-centered d-flex align-items-center justify-content-center">
    <div class="col-md-10 col-lg-8">

        <div class="details-card shadow-lg">
            <div class="details-header text-center pt-3">
                <h2 class="text-white fw-bold tracking-wider mb-0">EXPEDIENTE DEL CLIENTE</h2>
                <div class="underline-blue mx-auto"></div>
            </div>

            <div class="details-body px-4 py-3">

                <div class="info-item mb-2">
                    <label class="text-info-muted small fw-bold text-uppercase mb-0">ID de Cliente</label>
                    <div class="text-white">@Html.DisplayFor(model => model.Id)</div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-6">
                        <label class="text-info-muted small fw-bold text-uppercase mb-0">Nombre</label>
                        <div class="text-white">@Html.DisplayFor(model => model.Nombre_Cli)</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-info-muted small fw-bold text-uppercase mb-0">Apellido</label>
                        <div class="text-white">@Html.DisplayFor(model => model.Apellido_Cli)</div>
                    </div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-6">
                        <label class="text-info-muted small fw-bold text-uppercase mb-0">Contacto</label>
                        <div class="text-white">
                            <i class="bi bi-telephone text-info me-1 small"></i> @Html.DisplayFor(model => model.Telefono_Cli)
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-info-muted small fw-bold text-uppercase mb-0">Correo</label>
                        <div class="text-white text-truncate">
                            <i class="bi bi-envelope-at text-info me-1 small"></i> @Html.DisplayFor(model => model.Correo_Cli)
                        </div>
                    </div>
                </div>

                <div class="info-item mb-3">
                    <label class="text-info-muted small fw-bold text-uppercase mb-0">Seguridad (Hash)</label>
                    <div class="text-white small bg-black p-2 rounded border border-dark text-break" style="font-family: monospace; opacity: 0.8;">
                        @Html.DisplayFor(model => model.contraseña_Cli)
                    </div>
                </div>

                <div class="row gx-2">
                    <div class="col-6">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-action-blue w-100 py-2">
                            <i class="bi bi-pencil-square me-2"></i>MODIFICAR
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-action="Index" class="btn-action-outline w-100 py-2">
                            <i class="bi bi-arrow-left-circle me-2"></i>VOLVER
                        </a>
                    </div>
                </div>

            </div>

            <div class="details-footer text-center pb-2">
                <span class="badge bg-dark border border-info text-info x-small">CLIENTE REGISTRADO</span>
            </div>
        </div>
    </div>
</div>

<style>
    .full-bg-centered {
        background: radial-gradient(circle at center, rgba(0,0,0,0.7), rgba(0,0,0,0.95)), url('https://images.unsplash.com/photo-1512690196236-d5a232933339?auto=format&fit=crop&w=1350&q=80');
        background-size: cover;
        background-position: center;
        min-height: 100vh;
        width: 100%;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1000;
        overflow-y: auto;
        padding: 20px 0;
    }

    .details-card {
        background: rgba(10, 10, 10, 0.95);
        border: 1px solid #0dcaf0;
        border-radius: 12px;
    }

    .underline-blue {
        height: 2px;
        width: 40px;
        background: #0dcaf0;
        margin-top: 5px;
    }

    .text-info-muted {
        color: rgba(13, 202, 240, 0.7) !important;
        font-size: 0.75rem;
    }

    .text-break {
        word-wrap: break-word !important;
        word-break: break-all !important;
    }

    .x-small {
        font-size: 0.65rem;
    }

    .btn-action-blue {
        background: linear-gradient(90deg, #0dcaf0 0%, #0056b3 100%);
        color: white !important;
        border-radius: 6px;
        font-weight: bold;
        text-align: center;
        text-decoration: none;
        display: block;
        font-size: 0.85rem;
    }

    .btn-action-outline {
        background: transparent;
        color: #0dcaf0 !important;
        border: 1px solid #0dcaf0;
        border-radius: 6px;
        font-weight: bold;
        text-align: center;
        text-decoration: none;
        display: block;
        font-size: 0.85rem;
    }
</style>