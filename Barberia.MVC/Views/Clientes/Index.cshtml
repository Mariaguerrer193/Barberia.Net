@model IEnumerable<Barberia.Modelos.Cliente>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nombre_Cli)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Apellido_Cli)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Telefono_Cli)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Correo_Cli)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.contraseña_Cli)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre_Cli)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Apellido_Cli)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Telefono_Cli)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Correo_Cli)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.contraseña_Cli)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id=item.Id }) |
                @Html.ActionLink("Details", "Details", new { id=item.Id }) |
                @Html.ActionLink("Delete", "Delete", new { id=item.Id })
            </td>
        </tr>
}
    </tbody>
</table>
